# ============================================================================
# CAESAR — пример переменных окружения для прод-деплоя.
# Скопируйте в .env и заполните реальными значениями. НЕ коммитьте .env.
# Те же ключи задаются как GitHub Secrets для CI/CD (см. README деплоя).
# ============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=caesar_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=caesar_db

# ---- Сервер (.NET): JWT ----
# Секрет должен быть длинным случайным (>= 32 символов).
JWT_SECRET=change_me_to_a_long_random_secret_key_min_32_chars
JWT_ISSUER=CAESAR
JWT_AUDIENCE=CAESAR

# ---- Общий секрет «сервер <-> бот» ----
# Одно и то же значение читают и сервер (Telegram__BotSecret), и бот (CAESAR_BOT_SECRET).
TELEGRAM_BOT_SECRET=change_me_shared_bot_secret

# ---- Публикация сервера ----
SERVER_PORT=8080

# ---- Telegram-бот ----
BOT_TOKEN=123456789:your_telegram_bot_token
# Базовый URL API CAESAR, который видит бот. Внутри compose это http://server:8080
CAESAR_API_BASE=http://server:8080
OPENAI_API_KEY=sk-your_openai_key
OPENAI_MODEL=gpt-4o

# ---- (Опционально) теги образов в реестре ----
# REGISTRY_IMAGE_SERVER=ghcr.io/matveitolo/caesar-server
# REGISTRY_IMAGE_BOT=ghcr.io/matveitolo/caesar-bot
# IMAGE_TAG=latest
