+# ============================================================================
+# CAESAR — пример переменных окружения для прод-деплоя.
+# Скопируйте в .env и заполните реальными значениями. НЕ коммитьте .env.
+# Те же ключи задаются как GitHub Secrets для CI/CD (см. README деплоя).
+# ============================================================================
+
+# ---- PostgreSQL ----
+POSTGRES_USER=caesar_admin
+POSTGRES_PASSWORD=change_me_strong_password
+POSTGRES_DB=caesar_db
+
+# ---- Сервер (.NET): JWT ----
+# Секрет должен быть длинным случайным (>= 32 символов).
+JWT_SECRET=change_me_to_a_long_random_secret_key_min_32_chars
+JWT_ISSUER=CAESAR
+JWT_AUDIENCE=CAESAR
+
+# ---- Общий секрет «сервер <-> бот» ----
+# Одно и то же значение читают и сервер (Telegram__BotSecret), и бот (CAESAR_BOT_SECRET).
+TELEGRAM_BOT_SECRET=change_me_shared_bot_secret
+
+# ---- Публикация сервера ----
+SERVER_PORT=8080
+
+# ---- Telegram-бот ----
+BOT_TOKEN=123456789:your_telegram_bot_token
+# Базовый URL API CAESAR, который видит бот. Внутри compose это http://server:8080
+CAESAR_API_BASE=http://server:8080
+OPENAI_API_KEY=sk-your_openai_key
+OPENAI_MODEL=gpt-4o
+
+# ---- (Опционально) теги образов в реестре ----
+# REGISTRY_IMAGE_SERVER=ghcr.io/matveitolo/caesar-server
+# REGISTRY_IMAGE_BOT=ghcr.io/matveitolo/caesar-bot
+# IMAGE_TAG=latest
diff --git a/.github/workflows/deploy.yml b/.github/workflows/deploy.yml
new file mode 100644
index 0000000..a79d2f9
--- /dev/null
+++ b/.github/workflows/deploy.yml
@@ -0,0 +1,97 @@
+name: Build & Push (CAESAR)
+
+# Собирает образы сервера (с фронтом внутри) и Telegram-бота
+# и публикует их в GitHub Container Registry (GHCR).
+on:
+  push:
+    branches: [ main, master ]
+  workflow_dispatch:
+
+env:
+  REGISTRY: ghcr.io
+  IMAGE_SERVER: ${{ github.repository }}-server
+  IMAGE_BOT: ${{ github.repository }}-bot
+
+jobs:
+  build-and-push:
+    runs-on: ubuntu-latest
+    permissions:
+      contents: read
+      packages: write   # нужно для пуша в GHCR через GITHUB_TOKEN
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Set up Docker Buildx
+        uses: docker/setup-buildx-action@v3
+
+      - name: Log in to GHCR
+        uses: docker/login-action@v3
+        with:
+          registry: ${{ env.REGISTRY }}
+          username: ${{ github.actor }}
+          password: ${{ secrets.GITHUB_TOKEN }}
+
+      # ---------- Сервер (.NET + React-клиент) ----------
+      - name: Server metadata
+        id: meta_server
+        uses: docker/metadata-action@v5
+        with:
+          images: ${{ env.REGISTRY }}/${{ env.IMAGE_SERVER }}
+          tags: |
+            type=raw,value=latest
+            type=sha,format=short
+
+      - name: Build & push server
+        uses: docker/build-push-action@v6
+        with:
+          context: .
+          file: CAESAR.Server/Dockerfile
+          push: true
+          tags: ${{ steps.meta_server.outputs.tags }}
+          labels: ${{ steps.meta_server.outputs.labels }}
+          cache-from: type=gha
+          cache-to: type=gha,mode=max
+
+      # ---------- Telegram-бот ----------
+      - name: Bot metadata
+        id: meta_bot
+        uses: docker/metadata-action@v5
+        with:
+          images: ${{ env.REGISTRY }}/${{ env.IMAGE_BOT }}
+          tags: |
+            type=raw,value=latest
+            type=sha,format=short
+
+      - name: Build & push bot
+        uses: docker/build-push-action@v6
+        with:
+          context: ./bot
+          file: bot/Dockerfile
+          push: true
+          tags: ${{ steps.meta_bot.outputs.tags }}
+          labels: ${{ steps.meta_bot.outputs.labels }}
+          cache-from: type=gha
+          cache-to: type=gha,mode=max
+
+  # ----------------------------------------------------------------------------
+  # (Опционально) авто-деплой на ваш сервер по SSH после публикации образов.
+  # Требует секретов DEPLOY_HOST / DEPLOY_USER / DEPLOY_SSH_KEY и наличия на
+  # сервере docker-compose.prod.yml + .env. Раскомментируйте при необходимости.
+  # ----------------------------------------------------------------------------
+  # deploy:
+  #   needs: build-and-push
+  #   runs-on: ubuntu-latest
+  #   steps:
+  #     - name: Deploy over SSH
+  #       uses: appleboy/ssh-action@v1
+  #       with:
+  #         host: ${{ secrets.DEPLOY_HOST }}
+  #         username: ${{ secrets.DEPLOY_USER }}
+  #         key: ${{ secrets.DEPLOY_SSH_KEY }}
+  #         script: |
+  #           cd /opt/caesar
+  #           echo "${{ secrets.GITHUB_TOKEN }}" | docker login ghcr.io -u ${{ github.actor }} --password-stdin
+  #           docker compose -f docker-compose.prod.yml pull
+  #           docker compose -f docker-compose.prod.yml up -d
