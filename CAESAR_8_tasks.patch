+  border: 1px solid rgba(255, 255, 255, 0.1);
+  margin-bottom: 14px;
+}
+.consent-modal__title {
+  margin: 0 0 6px;
+  font-family: 'Cinzel', serif;
+  font-weight: 500;
+  font-size: 22px;
+  letter-spacing: 0.5px;
+  color: #ffffff;
+  line-height: 1.3;
+  padding-right: 32px;
+}
+.consent-modal__subtitle {
+  margin: 0;
+  font-size: 13px;
+  color: rgba(255, 255, 255, 0.35);
+}
+
+.consent-modal__body {
+  padding: 22px 36px 26px;
+  overflow-y: auto;
+  color: rgba(255, 255, 255, 0.62);
+  font-size: 14px;
+  line-height: 1.7;
+}
+.consent-modal__body p { margin: 0 0 14px; }
+.consent-modal__body ul {
+  margin: 0 0 14px;
+  padding-left: 4px;
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+.consent-modal__body li {
+  position: relative;
+  padding-left: 20px;
+}
+.consent-modal__body li::before {
+  content: '';
+  position: absolute;
+  left: 4px;
+  top: 9px;
+  width: 5px;
+  height: 5px;
+  border-radius: 50%;
+  background: rgba(255, 255, 255, 0.4);
+}
+.consent-modal__note {
+  margin-top: 4px;
+  padding: 14px 16px;
+  border-radius: 12px;
+  background: rgba(255, 255, 255, 0.04);
+  border: 1px solid rgba(255, 255, 255, 0.07);
+  color: rgba(255, 255, 255, 0.78);
+  font-size: 13.5px;
+}
+.consent-modal__body::-webkit-scrollbar { width: 6px; }
+.consent-modal__body::-webkit-scrollbar-thumb {
+  background: rgba(255, 255, 255, 0.12);
+  border-radius: 3px;
+}
+
+.consent-modal__footer {
+  display: flex;
+  gap: 12px;
+  justify-content: flex-end;
+  padding: 18px 36px 28px;
+  border-top: 1px solid rgba(255, 255, 255, 0.06);
+}
+.consent-modal__btn {
+  padding: 11px 22px;
+  border-radius: 999px;
+  font-size: 14px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+.consent-modal__btn--ghost {
+  background: transparent;
+  border: 1px solid rgba(255, 255, 255, 0.14);
+  color: rgba(255, 255, 255, 0.6);
+}
+.consent-modal__btn--ghost:hover {
+  border-color: rgba(255, 255, 255, 0.3);
+  color: #ffffff;
+}
+.consent-modal__btn--accent {
+  background: linear-gradient(135deg, #ffffff 0%, #e8e8e8 100%);
+  border: none;
+  color: #0a0a0a;
+  box-shadow: 0 8px 24px rgba(255, 255, 255, 0.12);
+}
+.consent-modal__btn--accent:hover {
+  transform: translateY(-2px);
+  box-shadow: 0 12px 32px rgba(255, 255, 255, 0.2);
+}
+
+@media (max-width: 560px) {
+  .consent-modal__header { padding: 28px 22px 18px; }
+  .consent-modal__body { padding: 20px 22px; }
+  .consent-modal__footer { padding: 16px 22px 24px; flex-direction: column-reverse; }
+  .consent-modal__btn { width: 100%; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .consent-modal, .consent-modal__card { animation: none; }
+}
