+/* ====================================================== */
+/* СОГЛАСИЕ 152-ФЗ — чекбокс + модальное окно             */
+/* ====================================================== */
+
+/* ---- Чекбокс согласия ---- */
+.register-consent {
+  display: flex;
+  align-items: flex-start;
+  gap: 11px;
+  margin: 2px 0 4px;
+  cursor: pointer;
+  user-select: none;
+}
+.register-consent__checkbox {
+  position: absolute;
+  opacity: 0;
+  width: 0;
+  height: 0;
+}
+.register-consent__box {
+  flex-shrink: 0;
+  width: 20px;
+  height: 20px;
+  margin-top: 1px;
+  border-radius: 6px;
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  background: rgba(255, 255, 255, 0.04);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: #0a0a0a;
+  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+.register-consent__box svg {
+  opacity: 0;
+  transform: scale(0.5);
+  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+.register-consent__checkbox:checked + .register-consent__box {
+  background: #ffffff;
+  border-color: #ffffff;
+  box-shadow: 0 0 16px rgba(255, 255, 255, 0.25);
+}
+.register-consent__checkbox:checked + .register-consent__box svg {
+  opacity: 1;
+  transform: scale(1);
+}
+.register-consent__checkbox:focus-visible + .register-consent__box {
+  outline: 2px solid rgba(255, 255, 255, 0.4);
+  outline-offset: 2px;
+}
+.register-consent__text {
+  font-size: 13px;
+  line-height: 1.5;
+  color: rgba(255, 255, 255, 0.45);
+}
+.register-consent__link {
+  background: none;
+  border: none;
+  padding: 0;
+  font: inherit;
+  color: rgba(255, 255, 255, 0.85);
+  text-decoration: underline;
+  text-underline-offset: 2px;
+  cursor: pointer;
+  transition: color 0.2s;
+}
+.register-consent__link:hover { color: #ffffff; }
+
+/* ---- Модальное окно согласия ---- */
+.consent-modal {
+  position: fixed;
+  inset: 0;
+  z-index: 100;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: 24px;
+  background: rgba(5, 5, 5, 0.72);
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+  animation: consentFade 0.25s ease forwards;
+}
+@keyframes consentFade {
+  from { opacity: 0; }
+  to   { opacity: 1; }
+}
+
+.consent-modal__card {
+  position: relative;
+  width: 100%;
+  max-width: 560px;
+  max-height: 86vh;
+  display: flex;
+  flex-direction: column;
+  border-radius: 24px;
+  background:
+    radial-gradient(circle at 18% 0%, rgba(60, 60, 60, 0.35) 0%, transparent 60%),
